{
  "comments": {
    // RouterOS usa '#' para comentarios de línea y no tiene comentarios de bloque.
    "lineComment": "#"
  },
  // symbols used as brackets
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"]
  ],
  // symbols that are auto closed when typing
  "autoClosingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  // symbols that that can be used to surround a selection
  "surroundingPairs": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""]
  ],
  // Incluye '$', '-' y '_' para que identificadores como `un-parametro` o `$mi-var`
  // se traten como una sola palabra (doble clic, selección, sugerencias).
  "wordPattern": "\\$?[A-Za-z0-9_][A-Za-z0-9_\\-]*",
  "folding": {
    "markers": {
      "start": "^\\s*#\\s*region\\b",
      "end": "^\\s*#\\s*endregion\\b"
    }
  }
}
