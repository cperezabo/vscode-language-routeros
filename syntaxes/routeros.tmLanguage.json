{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "RouterOS",
  "scopeName": "source.routeros",
  "fileTypes": [
    "rsc"
  ],
  "patterns": [
    {
      "include": "#embedded-code"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#comments"
    },
    {
      "include": "#scripting-commands"
    },
    {
      "include": "#command-path"
    },
    {
      "include": "#parameters"
    },
    {
      "include": "#commands"
    },
    {
      "include": "#variables"
    },
    {
      "include": "#internal-id"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    },
    {
      "include": "#punctuation"
    }
  ],
  "repository": {
    "embedded-code": {
      "comment": "A few fields hold RouterOS code in their string value (a script body or an event handler), so we re-tokenize the content as source.routeros. The field list is enumerated — a deliberate exception to the otherwise structural grammar — because nothing in the syntax marks a string as code; the names were taken from the router itself (value-type symbol \"Script\", plus \"source\"), see tooling/. The leading lookbehind keeps a longer name like 'my-source' from matching, and requiring '=' right after the name keeps 'on-fail-retry-time' from matching 'on-fail'. Escaped quotes (\\\") do not close the string.",
      "begin": "(?<![\\w./-])(source|script|on-event|on-up|on-down|on-login|on-logout|on-alert|on-backup|on-fail|on-master|up-script|down-script|test-script|lease-script|binding-script)(=)(\")",
      "beginCaptures": {
        "1": {
          "name": "entity.other.attribute-name.routeros"
        },
        "2": {
          "name": "keyword.operator.assignment.routeros"
        },
        "3": {
          "name": "punctuation.definition.string.begin.routeros"
        }
      },
      "end": "\"",
      "endCaptures": {
        "0": {
          "name": "punctuation.definition.string.end.routeros"
        }
      },
      "name": "meta.embedded.routeros",
      "patterns": [
        {
          "match": "\\\\(\\\\|[nrt$?\"abfv]|[0-9A-Fa-f]{2})",
          "name": "constant.character.escape.routeros"
        },
        {
          "include": "$self"
        }
      ]
    },
    "comments": {
      "match": "#.*$",
      "name": "comment.line.number-sign.routeros"
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.routeros",
      "patterns": [
        {
          "match": "\\\\(\\\\|[nrt$?\"abfv]|[0-9A-Fa-f]{2})",
          "name": "constant.character.escape.routeros"
        },
        {
          "match": "\\\\.",
          "name": "invalid.illegal.unknown-escape.routeros"
        },
        {
          "match": "\\$(\"[^\"]*\"|[A-Za-z0-9_][\\w-]*)",
          "name": "variable.other.routeros"
        }
      ]
    },
    "scripting-commands": {
      "patterns": [
        {
          "match": "(:)(if|else|elif|for|foreach|do|while|return|break|continue|error|onerror|exit)\\b",
          "name": "keyword.control.routeros",
          "captures": {
            "1": {
              "name": "punctuation.definition.keyword.routeros"
            }
          }
        },
        {
          "match": "(:)(global|local|set|put|log|delay|beep|parse|len|find|pick|typeof|toarray|tobool|tonum|tostr|toip|toip6|toid|totime|tonsec|tocrlf|tolf|resolve|convert|serialize|deserialize|environment|nothing|rndnum|rndstr|execute|jobname|time|timestamp|grep|retry|range)\\b",
          "name": "support.function.scripting.routeros",
          "captures": {
            "1": {
              "name": "punctuation.definition.keyword.routeros"
            }
          }
        }
      ]
    },
    "command-path": {
      "comment": "Config path: '/ip firewall filter' or '/ip/firewall/filter' (space- or slash-separated segments). The command lookahead ends the path before a command word so '/ip firewall filter add' keeps 'add' separate. A continuation segment must contain a letter ((?=[a-z0-9-]*[a-z])) and must be a whole token ending at a real separator: the trailing (?![a-z0-9.:=-]) forbids stopping mid-token or running into a '.', ':' or '=' (rejecting the token chars too, so greedy backtracking can't match one char short). So a host, IP, IPv6 or 'name=' value is left alone instead of being eaten: '/ping 8.8.8.8', '/ping example.com' and '/ping fe80::1' all stop the path at '/ping'. Every real menu segment has a letter (the only digit-initial one is '6to4').",
      "match": "(?:^|(?<=[\\s\\[]))/(?:(?!(?:add|set|get|print|export|import|edit|find|remove|enable|disable|move|unset)\\b)[a-z0-9][a-z0-9-]*)(?:[\\s/]+(?!(?:add|set|get|print|export|import|edit|find|remove|enable|disable|move|unset)\\b)(?=[a-z0-9-]*[a-z])[a-z0-9][a-z0-9-]*(?![a-z0-9.:=-]))*",
      "name": "support.class.routeros"
    },
    "commands": {
      "match": "\\b(add|set|get|print|export|import|edit|find|remove|enable|disable|move|unset)\\b",
      "name": "support.function.routeros"
    },
    "variables": {
      "match": "\\$(\"[^\"]*\"|[A-Za-z0-9_][\\w-]*)",
      "name": "variable.other.routeros"
    },
    "internal-id": {
      "comment": "Internal id like *1 or *FF. The lookbehind keeps the '*' multiplication operator (e.g. 2*3) from matching.",
      "match": "(?<![\\w)\\]])\\*[0-9A-Fa-f]+\\b",
      "name": "constant.numeric.id.routeros"
    },
    "parameters": {
      "comment": "Any 'name=' is a parameter — generic, no name list, so every RouterOS version is covered. The name charset allows '.', '/', '-' and a leading digit for real params like channel.band, rates-a/g and 802.3-sap.",
      "match": "([A-Za-z0-9][A-Za-z0-9./-]*)(=)(?!=)",
      "captures": {
        "1": {
          "name": "entity.other.attribute-name.routeros"
        },
        "2": {
          "name": "keyword.operator.assignment.routeros"
        }
      }
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(true|false|yes|no)\\b",
          "name": "constant.language.boolean.routeros"
        },
        {
          "match": "\\bnil\\b",
          "name": "constant.language.null.routeros"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "comment": "Clock time HH:MM[:SS]. The lookarounds stop it from biting into a longer ':'-separated value such as a MAC or client-id.",
          "match": "(?<![\\w:])\\d{1,2}:\\d{2}(:\\d{2})?(?![\\d:])",
          "name": "constant.numeric.time.routeros"
        },
        {
          "comment": "IPv6 address/prefix. The leading lookahead requires a '::' or a full 8-group form, so plain MACs (6 single-colon groups) are NOT eaten here.",
          "match": "(?<![\\w.])(?=[0-9A-Fa-f:]*::|(?:[0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f])(?:[0-9A-Fa-f]{1,4})?(?::(?:[0-9A-Fa-f]{1,4})?){1,7}(?:/\\d{1,3})?",
          "name": "constant.numeric.ipv6.routeros"
        },
        {
          "comment": "MAC and DHCP client-id: 3+ hex groups separated by ':'. Matched as a single token so values like 1:94:dd:f8:37:2a:94 do not split.",
          "match": "\\b[0-9A-Fa-f]{1,2}(:[0-9A-Fa-f]{1,2}){2,}\\b",
          "name": "constant.numeric.mac.routeros"
        },
        {
          "match": "\\b\\d{1,3}(\\.\\d{1,3}){3}(/\\d{1,2})?\\b",
          "name": "constant.numeric.ip.routeros"
        },
        {
          "match": "\\b(?:\\d+[wdhms])+\\b",
          "name": "constant.numeric.time.routeros"
        },
        {
          "match": "\\b\\d+(\\.\\d+)?[kKmMgG]\\b",
          "name": "constant.numeric.routeros"
        },
        {
          "match": "\\b(0x[0-9A-Fa-f]+|\\d+)\\b",
          "name": "constant.numeric.routeros"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "match": "->",
          "name": "keyword.operator.accessor.routeros"
        },
        {
          "match": "<=|>=|!=",
          "name": "keyword.operator.comparison.routeros"
        },
        {
          "match": "<<|>>",
          "name": "keyword.operator.bitwise.routeros"
        },
        {
          "match": "&&|\\|\\|",
          "name": "keyword.operator.logical.routeros"
        },
        {
          "match": "\\b(and|or|not|in)\\b",
          "name": "keyword.operator.logical.routeros"
        },
        {
          "match": "[<>]",
          "name": "keyword.operator.comparison.routeros"
        },
        {
          "match": "!",
          "name": "keyword.operator.logical.routeros"
        },
        {
          "match": "[~^&|]",
          "name": "keyword.operator.bitwise.routeros"
        },
        {
          "match": "[+*/%]",
          "name": "keyword.operator.arithmetic.routeros"
        },
        {
          "match": "(?<=\\s)-(?=\\s)",
          "name": "keyword.operator.arithmetic.routeros"
        },
        {
          "match": "[.,]",
          "name": "keyword.operator.concatenation.routeros"
        },
        {
          "match": "=",
          "name": "keyword.operator.assignment.routeros"
        }
      ]
    },
    "punctuation": {
      "patterns": [
        {
          "match": "[\\[\\]]",
          "name": "punctuation.section.brackets.routeros"
        },
        {
          "match": "[(){}]",
          "name": "punctuation.section.block.routeros"
        },
        {
          "match": ";",
          "name": "punctuation.terminator.routeros"
        }
      ]
    }
  }
}
